    "@types/react-native": "^0.72.0",
    "typescript": "^5.0.0",
    "react": "^18.0.0",
    "react-native": "^0.72.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "files": [
    "lib",
