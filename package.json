  },
  "keywords": [
    "react-native",
    "security",
    "privacy",
    "screenshot",
    "screen-recording",
    "root-detection",
    "jailbreak",
    "app-shield"
  ],
  "author": "Salil Gupta",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
